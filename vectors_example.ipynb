    {
      "cell_type": "code",
      "execution_count": 7,
      "metadata": {
        "id": "n0XiQf-eEY0l"
      },
      "outputs": [],
      "source": [
        "async def call_llm(prompt, model=\"meta-llama/Llama-3.1-8B-Instruct\", temperature=0):\n",
        "    client = AsyncInferenceClient(token=HF_TOKEN)\n",
        "    response = await client.chat.completions.create(\n",
        "        model=model,\n",
        "        messages=[{\"role\": \"user\", \"content\": prompt}],\n",
        "        temperature=temperature\n",
        "    )\n",
        "    return response.choices[0].message.content.strip()"
      ]
    },
