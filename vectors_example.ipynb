          "name": "stdout",
          "output_type": "stream",
          "text": [
            "banana vs strawberry: [[0.83642113]]\n",
            "banana vs destruction: [[0.23221526]]\n"
          ]
        }
      ],
      "source": [
        "banana_vs_strawberry = cosine_similarity([embeddings[0]], [embeddings[1]])\n",
        "banana_vs_destruction = cosine_similarity([embeddings[0]], [embeddings[2]])\n",
        "\n",
        "print(\"banana vs strawberry:\", banana_vs_strawberry)\n",
        "print(\"banana vs destruction:\", banana_vs_destruction)"
      ]
    },
